  m_Script: {fileID: 11500000, guid: 0c184bb4d7e368443bbfd8503f08a0d8, type: 3}
  m_Name: TalkDataShow
  m_EditorClassIdentifier: 
  data:
  - name: "\u963F\u53E4"
    talkText: "\u6B22\u8FCE\u6765\u5230\u7F8E\u4E3D\u7684\u5927\u96EA\u5C71\u3002\u6211\u4EEC\u5C06\u901A\u8FC7\u4E00\u4E2A\u6709\u8DA3\u7684\u5B9E\u9A8C\u6765\u63A2\u7D22\u6469\u64E6\u529B\u7684\u5965\u79D8\u3002\u4F60\u51C6\u5907\u597D\u4E86\u5417\uFF1F"
  - name: "\u963F\u53E4"
    talkText: "\u5728\u53E4\u4EE3\uFF0C\u7269\u7406\u5B66\u5BB6\u4EEC\u5C31\u5BF9\u7269\u4F53\u4E4B\u95F4\u7684\u6469\u64E6\u73B0\u8C61\u4EA7\u751F\u4E86\u6D53\u539A\u7684\u5174\u8DA3\u3002\u6469\u64E6\u529B\u662F\u4E00\u79CD\u963B\u788D\u7269\u4F53\u76F8\u5BF9\u8FD0\u52A8\u7684\u529B\uFF0C\u5B83\u5728\u6211\u4EEC\u7684\u65E5\u5E38\u751F\u6D3B\u4E2D\u65E0\u5904\u4E0D\u5728\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u6BD4\u5982\uFF0C\u4F60\u8D70\u8DEF\u65F6\u811A\u4E0E\u5730\u9762\u4E4B\u95F4\u7684\u6469\u64E6\u529B\uFF0C\u8BA9\u4F60\u80FD\u591F\u7A33\u7A33\u5730\u7AD9\u7ACB\u548C\u884C\u8D70\uFF1B\u800C\u6C7D\u8F66\u8F6E\u80CE\u4E0E\u5730\u9762\u7684\u6469\u64E6\u529B\uFF0C\u5219\u8BA9\u6C7D\u8F66\u80FD\u591F\u52A0\u901F\u3001\u5239\u8F66\u548C\u8F6C\u5F2F\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u5728\u8FD9\u4E2A\u5B9E\u9A8C\u4E2D\uFF0C\u6211\u4EEC\u5C06\u901A\u8FC7\u6254\u4E0B\u540C\u8D28\u91CF\u7684\u6728\u5934\u3001\u77F3\u5934\u548C\u91D1\u5C5E\u7269\u4F53\uFF0C\u6765\u89C2\u5BDF\u5B83\u4EEC\u5728\u4E0D\u540C\u8868\u9762\u4E0A\u7684\u6ED1\u52A8\u60C5\u51B5\uFF0C\u4ECE\u800C\u4E86\u89E3\u6469\u64E6\u529B\u7684\u5F71\u54CD\u56E0\u7D20\u3002\u867D\u7136\u8FD9\u4E9B\u7269\u4F53\u7684\u8D28\u91CF\u76F8\u540C\uFF0C\u4F46\u5B83\u4EEC\u7684\u6750\u8D28\u4E0D\u540C\uFF0C\u8FD9\u4F1A\u5BFC\u81F4\u5B83\u4EEC\u4E0E\u63A5\u89E6\u9762\u4E4B\u95F4\u7684\u6469\u64E6\u529B\u4E0D\u540C\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u90A3\u4E48\uFF0C\u8BF7\u4F60\u901A\u8FC7\u91CA\u653E\u4E0D\u540C\u7684\u5C0F\u7403\uFF0C\u89C2\u5BDF\u5B83\u4EEC\u4E0B\u843D\u7684\u65F6\u95F4\uFF08\u5C0F\u7403\u8D28\u91CF\u76F8\u540C\uFF09\uFF0C\u89C2\u5BDF\u4E09\u4E2A\u5C0F\u7403\u4E4B\u95F4\u7684\u5173\u7CFB\u5427\uFF01"
  - name: "\u963F\u53E4"
    talkText: "\u901A\u8FC7\u6309\u4E0B1 2 3\u6309\u952E\u9009\u62E9\u4E0D\u540C\u7684\u5C0F\u7403\uFF0C\u5E76\u4E14\u6309\u4E0BTap\u8FDB\u884C\u91CA\u653E\u3002"
