  m_Script: {fileID: 11500000, guid: 0c184bb4d7e368443bbfd8503f08a0d8, type: 3}
  m_Name: TalkDataTa
  m_EditorClassIdentifier: 
  data:
  - name: "\u963F\u53E4"
    talkText: "\u6B22\u8FCE\u6765\u5230\u8457\u540D\u7684\u201C\u6BD4\u8428\u659C\u5854\u5B9E\u9A8C\u201D"
  - name: "\u963F\u53E4"
    talkText: "\u8FD9\u91CC\u662F\u4E00\u4E2A\u91CD\u73B0\u4F3D\u5229\u7565\u7ECF\u5178\u5B9E\u9A8C\u7684\u865A\u62DF\u573A\u666F\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u4F60\u77E5\u9053\u5417\uFF1F1590\u5E74\uFF0C\u4F3D\u5229\u7565\u5728\u6BD4\u8428\u659C\u5854\u4E0A\u8FDB\u884C\u4E86\u4E00\u9879\u8457\u540D\u7684\u5B9E\u9A8C\uFF0C\u63A8\u7FFB\u4E86\u4E9A\u91CC\u58EB\u591A\u5FB7\u5173\u4E8E\u7269\u4F53\u4E0B\u843D\u901F\u5EA6\u4E0E\u8D28\u91CF\u6210\u6B63\u6BD4\u7684\u89C2\u70B9\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u5728\u8FD9\u4E2A\u5B9E\u9A8C\u4E2D\uFF0C\u4F3D\u5229\u7565\u540C\u65F6\u91CA\u653E\u4E86\u4E24\u4E2A\u8D28\u91CF\u4E0D\u540C\u7684\u7269\u4F53\uFF0C\u7ED3\u679C\u5B83\u4EEC\u51E0\u4E4E\u540C\u65F6\u843D\u5730\u3002\u8FD9\u8BC1\u660E\u4E86\u5728\u5FFD\u7565\u7A7A\u6C14\u963B\u529B\u7684\u60C5\u51B5\u4E0B\uFF0C\u6240\u6709\u7269\u4F53\u5728\u91CD\u529B\u4F5C\u7528\u4E0B\u4EE5\u76F8\u540C\u7684\u52A0\u901F\u5EA6\u4E0B\u843D\u3002\u8FD9\u4E2A\u5B9E\u9A8C\u4E0D\u4EC5\u9A8C\u8BC1\u4E86\u81EA\u7531\u843D\u4F53\u8FD0\u52A8\u7684\u89C4\u5F8B\uFF0C\u8FD8\u4E3A\u540E\u6765\u7684\u7269\u7406\u5B66\u53D1\u5C55\u5960\u5B9A\u4E86\u57FA\u7840\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u5728\u8FD9\u91CC\uFF0C\u4F60\u53EF\u4EE5\u4EB2\u81EA\u64CD\u4F5C\u8FD9\u4E2A\u5B9E\u9A8C\u3002\u901A\u8FC7\u8C03\u6574\u7269\u4F53\u7684\u8D28\u91CF\u548C\u4E0B\u843D\u9AD8\u5EA6\uFF0C\u4F60\u53EF\u4EE5\u76F4\u89C2\u5730\u89C2\u5BDF\u5230\u4E0D\u540C\u8D28\u91CF\u7684\u7269\u4F53\u5728\u81EA\u7531\u843D\u4F53\u8FD0\u52A8\u4E2D\u7684\u8868\u73B0\u3002\u4F60\u4F1A\u53D1\u73B0\uFF0C\u65E0\u8BBA\u7269\u4F53\u6709\u591A\u91CD\uFF0C\u5B83\u4EEC\u7684\u4E0B\u843D\u65F6\u95F4\u53EA\u4E0E\u9AD8\u5EA6\u548C\u91CD\u529B\u52A0\u901F\u5EA6\u6709\u5173\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u73B0\u5728\uFF0C\u4F60\u53EF\u4EE5\u5F00\u59CB\u4F60\u7684\u5B9E\u9A8C\u4E4B\u65C5\u4E86\uFF01"
  - name: "\u963F\u53E4"
    talkText: "\u5148\u6309\u4E0BO\u5065\u770B\u65E0\u7A7A\u6C14\u963B\u529B\u7684\u72B6\u6001\u4E0B\u4E24\u4E2A\u5C0F\u7403\u4E0B\u843D\u7684\u65F6\u95F4\u662F\u591A\u5C11\uFF0C\u518D\u901A\u8FC7\u6309Q\u548CR\u5065\u589E\u52A0\u7A7A\u6C14\u963B\u529B\uFF0C\u9A8C\u8BC1\u8FD9\u4E2A\u7ED3\u8BBA\u5427\uFF01"
