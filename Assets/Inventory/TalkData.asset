  m_Script: {fileID: 11500000, guid: 0c184bb4d7e368443bbfd8503f08a0d8, type: 3}
  m_Name: TalkData
  m_EditorClassIdentifier: 
  data:
  - name: "\u963F\u53E4"
    talkText: "\u60A8\u597D\u5440\uFF0C\u6B22\u8FCE\u6765\u5230\u8FD9\u91CC\uFF01"
  - name: "\u963F\u53E4"
    talkText: "\u8FD9\u91CC\u662F\u300A\u7269\u7406\u5E7B\u5883\u4E4B\u65C5\u300B\u7684\u53E4\u4EE3\u7269\u7406\u5C55\u9986\uFF0C\u5F88\u9AD8\u5174\u80FD\u548C\u4F60\u5728\u6B64\u76F8\u9047\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u5728\u8FD9\u91CC\uFF0C\u4F60\u5C06\u4F1A\u4E86\u89E3\u5230\u8BB8\u591A\u795E\u5947\u7684\u7269\u7406\u5B9E\u9A8C\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u4F60\u60F3\u77E5\u9053\u53E4\u4EE3\u7684\u667A\u8005\u4EEC\u90FD\u662F\u5982\u4F55\u505A\u5B9E\u9A8C\u7684\u5417\uFF1F"
  - name: "\u963F\u53E4"
    talkText: "\u770B\u5230\u524D\u9762\u7684\u51E0\u4E2A\u5927\u95E8\u4E86\u5417\uFF1F"
  - name: "\u963F\u53E4"
    talkText: "\u7A7F\u8FC7\u5B83\u4EEC\uFF0C\u4F60\u5C06\u4F1A\u5230\u8FBE\u4E00\u4E2A\u4E2A\u5947\u5999\u7684\u4E16\u754C\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u4F60\u5C06\u6210\u4E3A\u4E00\u540D\u5B66\u8005\uFF0C\u5728\u6709\u8DA3\u7684\u5B9E\u9A8C\u4E2D\u5B66\u4E60\u5230\u4E0D\u540C\u7684\u77E5\u8BC6\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u90A3\u4E48\uFF0C\u4E8B\u4E0D\u5B9C\u8FDF\uFF0C\u51FA\u53D1\u5427\uFF01"
  - name: "\u963F\u53E4"
    talkText: "\u795D\u4F60\u597D\u8FD0\u3002"
