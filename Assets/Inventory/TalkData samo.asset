  m_Script: {fileID: 11500000, guid: 0c184bb4d7e368443bbfd8503f08a0d8, type: 3}
  m_Name: TalkData samo
  m_EditorClassIdentifier: 
  data:
  - name: "\u963F\u53E4"
    talkText: "\u540C\u5B66\u4F60\u597D\u5440\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u60F3\u77E5\u9053\u70ED\u6C14\u7403\u662F\u600E\u4E48\u98DE\u8D77\u6765\u7684\u5417\uFF1F"
  - name: "\u963F\u53E4"
    talkText: "\u70ED\u6C14\u7403\u7684\u53D1\u660E\u8005\u662F\u6CD5\u56FD\u7684\u5B5F\u683C\u83F2\u5144\u5F1F\uFF08Montgolfier
      brothers\uFF09\uFF0C\u5373\u7EA6\u745F\u592B\xB7\u7C73\u6B47\u5C14\xB7\u5B5F\u683C\u83F2\uFF08Joseph-Michel
      Montgolfier\uFF09\u548C\u96C5\u514B\xB7\u827E\u8482\u5B89\xB7\u5B5F\u683C\u83F2\uFF08Jacques-\xC9tienne
      Montgolfier\uFF09\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u5B5F\u683C\u83F2\u5144\u5F1F\u51FA\u751F\u4E8E\u6CD5\u56FD\u7684\u4E00\u4E2A\u9020\u7EB8\u5546\u5BB6\u5EAD\u30021782\u5E74\uFF0C\u7EA6\u745F\u592B\xB7\u5B5F\u683C\u83F2\u5728\u5C06\u7EB8\u5C51\u6254\u8FDB\u706B\u7089\u65F6\uFF0C\u53D1\u73B0\u7EB8\u5C51\u4F1A\u4E0D\u65AD\u4E0A\u5347\uFF0C\u4ECE\u800C\u53D7\u5230\u542F\u53D1\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u4ED6\u8FDB\u884C\u4E86\u521D\u6B65\u5B9E\u9A8C\uFF0C\u7528\u4E00\u4EF6\u886C\u8863\u548C\u7F1D\u6210\u201C\u7ACB\u65B9\u5F62\u201D\u7684\u7EF8\u7F0E\u5E03\u6599\u8FDB\u884C\u52A0\u70ED\u5B9E\u9A8C\uFF0C\u53D1\u73B0\u8FD9\u4E9B\u7269\u4F53\u80FD\u591F\u968F\u7740\u70ED\u7A7A\u6C14\u4E0A\u5347\u3002"
  - name: "\u963F\u53E4"
    talkText: "1782\u5E7412\u6708\uFF0C\u5B5F\u683C\u83F2\u5144\u5F1F\u5728\u6CD5\u56FD\u963F\u8BFA\u5185\u8FDB\u884C\u4E86\u4E00\u6B21\u5B9E\u9A8C\uFF0C\u4ED6\u4EEC\u7528\u7EB8\u5236\u4F5C\u4E86\u4E00\u4E2A\u7ACB\u65B9\u4F53\uFF0C\u5E76\u4F7F\u5176\u4E0A\u5347\u523030\u7C73\u7684\u9AD8\u5EA6\u3002"
  - name: "\u963F\u53E4"
    talkText: "1783\u5E744\u6708\uFF0C\u4ED6\u4EEC\u5236\u9020\u4E86\u4E00\u4E2A\u76F4\u5F84\u4E3A12\u7C73\u3001\u4F53\u79EF\u4E3A800\u7ACB\u65B9\u7C73\u7684\u5927\u578B\u6C14\u7403\uFF0C\u5E76\u8FDB\u884C\u4E86\u521D\u6B65\u7684\u7CFB\u7559\u5B9E\u9A8C\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u540C\u5E746\u67084\u65E5\uFF0C\u4ED6\u4EEC\u5728\u91CC\u6602\u5B89\u8BFA\u5185\u5E7F\u573A\u8FDB\u884C\u4E86\u7B2C\u4E00\u6B21\u516C\u5F00\u8868\u6F14\uFF0C\u6C14\u7403\u4E0A\u5347\u52301000\u591A\u7C73\u7684\u9AD8\u5EA6\uFF0C\u5E76\u572810\u5206\u949F\u540E\u964D\u843D\u57282\u516C\u91CC\u5916\u7684\u5730\u65B9\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u540C\u5E746\u67084\u65E5\uFF0C\u4ED6\u4EEC\u5728\u91CC\u6602\u5B89\u8BFA\u5185\u5E7F\u573A\u8FDB\u884C\u4E86\u7B2C\u4E00\u6B21\u516C\u5F00\u8868\u6F14\uFF0C\u6C14\u7403\u4E0A\u5347\u52301000\u591A\u7C73\u7684\u9AD8\u5EA6\uFF0C\u5E76\u572810\u5206\u949F\u540E\u964D\u843D\u57282\u516C\u91CC\u5916\u7684\u5730\u65B9\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u70ED\u6C14\u7403\u662F\u4EBA\u7C7B\u6700\u65E9\u7684\u98DE\u884C\u5DE5\u5177\u4E4B\u4E00\uFF0C\u5176\u98DE\u884C\u539F\u7406\u57FA\u4E8E\u963F\u57FA\u7C73\u5FB7\u6D6E\u529B\u539F\u7406\u3002\u5F53\u7403\u56CA\u5185\u7684\u7A7A\u6C14\u88AB\u52A0\u70ED\u540E\uFF0C\u5BC6\u5EA6\u51CF\u5C0F\uFF0C\u4EA7\u751F\u5411\u4E0A\u7684\u6D6E\u529B\uFF0C\u4F7F\u70ED\u6C14\u7403\u5347\u7A7A\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u5728\u8FD9\u4E2A\u5B9E\u9A8C\uFF0C\u4F60\u5C06\u4F1A\u66F4\u52A0\u76F4\u89C2\u7684\u4E86\u89E3\u5230\u70ED\u6C14\u7403\u7684\u98DE\u884C\u3002"
  - name: "\u963F\u53E4"
    talkText: "\u5230\u8FBE\u8E0F\u677F\u957F\u6309Q\u53EF\u4EE5\u4F7F\u70ED\u6C14\u7403\u8FDB\u884C\u98DE\u884C\u3002"
